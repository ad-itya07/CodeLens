{
  "name": "codelens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm install && npx prisma generate",
    "dev": "nodemon --import tsx/esm ./src/server.js",
    "start": "node --import tsx/esm ./src/server.js",
    "worker": "node --import tsx/esm ./src/queue/worker.js",
    "start:prod": "concurrently \"npm start\" \"npm run worker\""
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-neon": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@xenova/transformers": "^2.17.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.1",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0"
  }
}
